msgid "Saudi National ID"
msgstr "هوية وطنية سعودية"

msgid "Resident ID (Iqama)"
msgstr "رقم إقامة"

msgid "The ID must contain exactly 10 digits."
msgstr "يجب أن يتكوّن رقم الهوية من ١٠ أرقام بالضبط."

msgid "Invalid Saudi ID number: it must start with 1 (National ID) or 2 (Iqama)."
msgstr "رقم الهوية غير صحيح: يجب أن يبدأ بـ ١ (هوية وطنية) أو ٢ (إقامة)."

msgid "Checksum validation failed. Please check the number you entered."
msgstr "فشل التحقق من صحة الرقم. يرجى مراجعة الرقم المُدخل."

msgid "Saudi identification number"
msgstr "رقم هوية سعودي"

msgid "This must be a @expected. @actual numbers are not accepted here."
msgstr "يجب أن يكون @expected. أرقام @actual غير مقبولة هنا."

msgid "Saudi ID Validator"
msgstr "التحقق من الهوية السعودية"

msgid "Validate matching fields automatically"
msgstr "التحقق تلقائيًا من الحقول المطابقة"

msgid "Field machine names"
msgstr "الأسماء البرمجية للحقول"

msgid "One machine name per line."
msgstr "اسم برمجي واحد في كل سطر."

msgid "Tell the user which type was detected"
msgstr "إظهار نوع الهوية المكتشَف للمستخدم"

msgid "Administer Saudi ID Validator"
msgstr "إدارة التحقق من الهوية السعودية"
